{
  "name": "EmployeeCompetencyAssessment",
  "type": "object",
  "properties": {
    "title_ar": {
      "type": "string",
      "default": "مقياس الكفاءات الأساسية للموظفين"
    },
    "title_en": {
      "type": "string",
      "default": "Employee Core Competency Assessment"
    },
    "description_ar": {
      "type": "string"
    },
    "description_en": {
      "type": "string"
    },
    "professional_level": {
      "type": "string",
      "enum": ["operational", "supervisory", "leadership"],
      "description": "المستوى الوظيفي: تشغيلي، إشرافي، قيادي"
    },
    "version": {
      "type": "string",
      "enum": ["quick", "full"],
      "description": "نسخة سريعة أو شاملة"
    },
    "price_sar": {
      "type": "number",
      "default": 99
    },
    "is_free": {
      "type": "boolean",
      "default": false
    },
    "is_published": {
      "type": "boolean",
      "default": false
    },
    "is_featured": {
      "type": "boolean",
      "default": true
    },
    "cover_image_url": {
      "type": "string"
    },
    "duration_minutes": {
      "type": "number"
    },
    "question_count": {
      "type": "number"
    },
    "domain_count": {
      "type": "number",
      "default": 6
    },
    "competency_count": {
      "type": "number",
      "default": 20
    },
    "sort_order": {
      "type": "number",
      "default": 0
    }
  },
  "required": ["title_ar", "title_en", "professional_level", "version"]
}