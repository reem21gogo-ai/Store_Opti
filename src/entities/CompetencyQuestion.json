{
  "name": "CompetencyQuestion",
  "type": "object",
  "properties": {
    "assessment_id": {
      "type": "string",
      "description": "معرف المقياس"
    },
    "professional_level": {
      "type": "string",
      "enum": ["operational", "supervisory", "leadership"]
    },
    "question_ar": {
      "type": "string"
    },
    "question_en": {
      "type": "string"
    },
    "question_type": {
      "type": "string",
      "enum": ["scenario", "behavior", "scale"]
    },
    "options": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "text_ar": { "type": "string" },
          "text_en": { "type": "string" },
          "score": { "type": "number" }
        }
      }
    },
    "domain": {
      "type": "string",
      "enum": [
        "thought_analysis",
        "results_execution",
        "people_collaboration",
        "self_leadership_growth",
        "customer_stakeholder_value",
        "digital_sustainability_compliance"
      ]
    },
    "competency": {
      "type": "string",
      "description": "الجدارة المحددة التي تقيسها الأسئلة"
    },
    "sort_order": {
      "type": "number",
      "default": 0
    }
  },
  "required": ["assessment_id", "professional_level", "question_ar", "question_en", "question_type", "options", "domain"]
}